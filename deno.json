{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run -A npm:vite",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview"
  },
  "imports": {
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^2.0.2",
    "@tangerie/remote-sqlite": "jsr:@tangerie/remote-sqlite@^1.2.1",
    "@tangerie/global-store": "jsr:@tangerie/global-store@^1.5.0",
    "codemirror": "npm:codemirror@^6.0.2",
    "@codemirror/lang-sql": "npm:@codemirror/lang-sql@^6.10.0",
    "@codemirror/state": "npm:@codemirror/state@^6.7.1",
    "@codemirror/view": "npm:@codemirror/view@^6.43.6",
    "vite": "npm:vite@^6.0.0",
    "@preact/preset-vite": "npm:@preact/preset-vite@^2.9.0",
    "preact": "npm:preact@^10.27.0",
    "tailwindcss": "npm:tailwindcss@^4.0.0",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.0.0"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  }
}
